<dashboard version="1.1" theme="dark" embed="enabled">
  <label>Ch5 — Custom Visualizations DS</label>
  <description>Demo: Legacy App Custom Viz, Own App Custom Viz, React/D3 Framework Viz</description>
  <row>
    <panel>
      <html>
        <style>
          .viz-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; padding: 8px; }
          .viz-card {
            background: #16213e;
            border-radius: 10px;
            padding: 20px;
            border: 2px solid #2d3748;
          }
          .viz-card.variant-1 { border-color: #e94560; }
          .viz-card.variant-2 { border-color: #f6ad55; }
          .viz-card.variant-3 { border-color: #68d391; }
          .viz-card h2 { font-size: 16px; margin: 0 0 4px 0; }
          .viz-card .tag {
            display: inline-block; font-size: 11px; padding: 2px 8px;
            border-radius: 12px; font-weight: 700; margin-bottom: 12px;
          }
          .variant-1 .tag { background: #e94560; color: white; }
          .variant-2 .tag { background: #f6ad55; color: #1a1a2e; }
          .variant-3 .tag { background: #68d391; color: #1a1a2e; }
          .viz-card p { color: #a0aec0; font-size: 13px; line-height: 1.6; margin: 0 0 12px 0; }
          .code-block {
            background: #0d1117; color: #79c0ff; font-family: monospace;
            font-size: 12px; padding: 12px; border-radius: 6px;
            white-space: pre-wrap; margin: 8px 0;
          }
          .pro { color: #68d391; } .con { color: #fc8181; }
          h3 { color: #e2e8f0; font-size: 14px; margin: 12px 0 6px 0; }
          ul { color: #a0aec0; font-size: 13px; padding-left: 18px; margin: 0; }
          li { margin-bottom: 4px; }
        </style>

        <div class="viz-grid">

          <!-- VARIANT 1: Legacy Custom Viz App -->
          <div class="viz-card variant-1">
            <h2>Variant 1: Legacy App Custom Viz</h2>
            <span class="tag">Splunk 6.4 – 8.x Style</span>
            <p>Older custom visualizations distributed as standalone Splunk apps, installed via Splunkbase. Works in Classic SimpleXML dashboards.</p>

            <h3>File structure</h3>
            <div class="code-block">appserver/static/
  visualizations/
    my_gauge/
      visualization.js   ← D3/Highcharts code
      package.json
      preview.png
default/
  visualizations.conf    ← registration
</div>

            <h3>Usage (SimpleXML)</h3>
            <div class="code-block">&lt;viz type="my_app.my_gauge"&gt;
  &lt;search&gt;...&lt;/search&gt;
&lt;/viz&gt;</div>

            <h3>Pros &amp; Cons</h3>
            <ul>
              <li class="pro">✅ Easy to install from Splunkbase</li>
              <li class="pro">✅ No build pipeline needed</li>
              <li class="con">⚠️ No native Dashboard Studio support</li>
              <li class="con">⚠️ Deprecated API</li>
              <li class="con">⚠️ No React support</li>
            </ul>
            <h3>Well-known apps</h3>
            <ul>
              <li>Force Directed App for Splunk</li>
              <li>Splunk 3D Graph</li>
              <li>Parallel Coordinates</li>
            </ul>
          </div>

          <!-- VARIANT 2: Own App Custom Viz -->
          <div class="viz-card variant-2">
            <h2>Variant 2: Own App – Custom Viz</h2>
            <span class="tag">Current method</span>
            <p>Custom visualizations as part of your own Splunk app, placed directly in the <code>appserver/static/visualizations/</code> folder. Supports Dashboard Studio via <code>@splunk/visualizations</code>.</p>

            <h3>File structure</h3>
            <div class="code-block">my_app/
  appserver/static/
    visualizations/
      my_viz/
        src/
          MyViz.jsx      ← React component
          index.js
        webpack.config.js
        package.json
  default/
    visualizations.conf</div>

            <h3>visualizations.conf</h3>
            <div class="code-block">[my_gauge]
label = My Custom Gauge
description = Custom D3 Gauge
allow_user_selection = true
source_type = json
data_sources.primary = required</div>

            <h3>Pros &amp; Cons</h3>
            <ul>
              <li class="pro">✅ Native Dashboard Studio integration</li>
              <li class="pro">✅ React + D3 + TypeScript possible</li>
              <li class="pro">✅ Theming via CSS variables</li>
              <li class="con">⚠️ Build pipeline (Webpack/Rollup) required</li>
              <li class="con">⚠️ Higher initial setup effort</li>
            </ul>
          </div>

          <!-- VARIANT 3: Framework Custom Viz -->
          <div class="viz-card variant-3">
            <h2>Variant 3: Custom Viz Framework</h2>
            <span class="tag">Modern / Recommended</span>
            <p>Full use of the <strong>@splunk/visualizations</strong> React framework including the Splunk UI Toolkit. Highest integration, theming support, and long-term maintainability.</p>

            <h3>Tech stack</h3>
            <div class="code-block">@splunk/visualizations     ← base viz types
@splunk/react-ui          ← UI components
@splunk/themes            ← Enterprise theming
@splunk/splunk-utils      ← Splunk utilities
d3 / echarts / THREE.js   ← rendering libraries</div>

            <h3>React component example</h3>
            <div class="code-block">import { registerVisualization }
  from '@splunk/visualizations';

const MyGauge = ({ dataSources, options }) =&gt; {
  const data = dataSources.primary.data;
  return (
    &lt;svg&gt;...&lt;/svg&gt;  // D3 or Canvas
  );
};

registerVisualization('my_gauge', MyGauge);</div>

            <h3>Pros &amp; Cons</h3>
            <ul>
              <li class="pro">✅ Full Dashboard Studio API</li>
              <li class="pro">✅ Enterprise/Dark theme automatic</li>
              <li class="pro">✅ Token integration out of the box</li>
              <li class="pro">✅ Drilldown support</li>
              <li class="con">⚠️ More complex setup</li>
              <li class="con">⚠️ Splunk UI Toolkit license dependency</li>
            </ul>
          </div>

        </div>
      </html>
    </panel>
  </row>
