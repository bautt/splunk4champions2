<dashboard version="1.1" theme="dark">
  <label>Weather — Events Index</label>
  <description>Open-Meteo weather analytics using regular search against s4c_meteo events index</description>

  <fieldset submitButton="false" autoRun="true">

    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-6h</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="dropdown" token="city" searchWhenChanged="true">
      <label>City</label>
      <choice value="*">All Cities</choice>
      <fieldForLabel>city</fieldForLabel>
      <fieldForValue>city</fieldForValue>
      <search>
        <query>index=s4c_meteo sourcetype=open_meteo:weather:json | stats count BY city | sort city | fields city</query>
        <earliest>-24h</earliest>
        <latest>now</latest>
      </search>
      <default>*</default>
    </input>

    <input type="dropdown" token="metric" searchWhenChanged="true">
      <label>Metric</label>
      <choice value="temperature_2m">Temperature (°C)</choice>
      <choice value="apparent_temperature">Feels Like (°C)</choice>
      <choice value="relative_humidity_2m">Humidity (%)</choice>
      <choice value="wind_speed_10m">Wind Speed (km/h)</choice>
      <choice value="wind_gusts_10m">Wind Gusts (km/h)</choice>
      <choice value="precipitation">Precipitation (mm)</choice>
      <choice value="rain">Rain (mm)</choice>
      <choice value="snowfall">Snowfall (cm)</choice>
      <choice value="cloud_cover">Cloud Cover (%)</choice>
      <choice value="pressure_msl">Pressure MSL (hPa)</choice>
      <choice value="surface_pressure">Surface Pressure (hPa)</choice>
      <default>temperature_2m</default>
    </input>

  </fieldset>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Row 1 — Event count + freshness                                        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <row>
    <panel>
      <single>
        <title>Events Indexed (Selected Period)</title>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| stats count
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Cities Reporting</title>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| stats dc(city) AS cities
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Last Ingest</title>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| stats max(_time) AS last_ingest
| eval last_ingest=strftime(last_ingest, "%Y-%m-%d %H:%M:%S %Z")
| fields last_ingest
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
      </single>
    </panel>
  </row>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Row 2 — Current conditions overview table                              -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <row>
    <panel>
      <title>Current Conditions — Latest Reading per City</title>
      <table>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| stats latest(temperature_2m)      AS "Temp °C"
        latest(apparent_temperature) AS "Feels Like °C"
        latest(relative_humidity_2m) AS "Humidity %"
        latest(wind_speed_10m)       AS "Wind km/h"
        latest(wind_gusts_10m)       AS "Gusts km/h"
        latest(precipitation)        AS "Precip mm"
        latest(cloud_cover)          AS "Cloud %"
        latest(pressure_msl)         AS "Pressure hPa"
        latest(weather_code)         AS "WMO Code"
  BY city, country
| eval "Temp °C"       = round('Temp °C', 1)
| eval "Feels Like °C" = round('Feels Like °C', 1)
| eval "Humidity %"    = round('Humidity %', 0)
| eval "Wind km/h"     = round('Wind km/h', 1)
| eval "Gusts km/h"    = round('Gusts km/h', 1)
| eval "Precip mm"     = round('Precip mm', 2)
| eval "Cloud %"       = round('Cloud %', 0)
| eval "Pressure hPa"  = round('Pressure hPa', 1)
| sort city
| fields city, country, "Temp °C", "Feels Like °C", "Humidity %", "Wind km/h", "Gusts km/h", "Precip mm", "Cloud %", "Pressure hPa", "WMO Code"
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="rowNumbers">false</option>
      </table>
    </panel>
  </row>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Row 3 — Selected metric trend over time                                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <row>
    <panel>
      <title>$metric$ — Trend Over Time by City</title>
      <chart>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| timechart span=15m avg($metric$) BY city
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="height">300</option>
      </chart>
    </panel>
  </row>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Row 4 — Bar ranking + statistics                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <row>
    <panel>
      <title>$metric$ — Latest Value per City</title>
      <chart>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| stats latest($metric$) AS value BY city
| eval value=round(value, 2)
| sort - value
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="height">280</option>
      </chart>
    </panel>

    <panel>
      <title>$metric$ — Statistics (Selected Period)</title>
      <table>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| stats avg($metric$) AS avg
        max($metric$) AS max
        min($metric$) AS min
        stdev($metric$) AS stdev
  BY city
| eval avg=round(avg,2), max=round(max,2), min=round(min,2), stdev=round(stdev,2)
| sort city
| rename avg AS "Avg", max AS "Max", min AS "Min", stdev AS "Std Dev"
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Row 5 — Raw events log                                                 -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <row>
    <panel>
      <title>Raw Events</title>
      <event>
        <search>
          <query>
index=s4c_meteo sourcetype=open_meteo:weather:json
| where "$city$"="*" OR city="$city$"
| sort - _time
| head 50
          </query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="list.drilldown">none</option>
        <option name="maxLines">5</option>
        <option name="type">list</option>
      </event>
    </panel>
  </row>

</dashboard>
